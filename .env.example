# Fast Focus (staging/prod) env example

# --- required ---
DATABASE_URL=postgres://fastfocus:fastfocus@127.0.0.1:55432/fastfocus
FF_ADMIN_TOKEN=change-me
FF_PUBLIC_BASE_URL=https://fastfocus.camera
# staging example: https://staging.fastfocus.camera
FF_TRUST_PROXY=1
FF_GOV_ROOT=./gov-snapshot
HOST=0.0.0.0
PORT=8080

# --- cookies / privacy ---
FF_COOKIE_SECURE=1

# --- robots / crawler policy (optional) ---
# comma-separated user agents to disallow (adds blocks to /robots.txt)
FF_ROBOTS_DISALLOW_USER_AGENTS=GPTBot,Google-Extended

# actively block “training” bots at the HTTP layer (in addition to robots)
FF_BLOCK_TRAINING_BOTS=0

# --- ops logs (optional) ---
FF_HTTP_REQUEST_LOGS_ENABLED=1
FF_IP_HASH_SALT=change-me

# --- batch refresh scheduler (optional) ---
FF_PRICE_BANDS_DATE=
FF_SCHEDULER_USE_DEMO=0
FF_SCHEDULER_RUN_EBAY=1
FF_SCHEDULER_RUN_RETAILER_FEED_1=0
FF_SCHEDULER_RUN_ALERTS=0
FF_SCHEDULER_RUN_NEWSLETTER=0

# --- eBay Browse API ingest (optional) ---
EBAY_ENV=production
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_US
FF_EBAY_CAMERA_SLUGS=canon-eos-r5,canon-eos-r6
FF_EBAY_LENS_SLUGS=
FF_EBAY_EXTRA_QUERIES=
FF_EBAY_LIMIT_PER_QUERY=25
FF_EBAY_PAGES_PER_QUERY=1

# --- email (optional; currently stdout only) ---
FF_EMAIL_TRANSPORT=stdout
FF_EMAIL_FROM=Fast Focus <noreply@fastfocus.example>

# --- affiliate params (optional) ---
FF_AFFILIATE_EBAY_PARAMS=campid=YOUR_ID&customid=ff_{listing_id}
