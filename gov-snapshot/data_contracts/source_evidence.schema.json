{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fastfocus.example/schemas/source_evidence.schema.json",
  "title": "SourceEvidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_id",
    "entity_type",
    "entity_id",
    "claim_path",
    "source_type",
    "source_url",
    "retrieved_at",
    "license",
    "confidence",
    "value",
    "notes"
  ],
  "properties": {
    "evidence_id": {
      "$ref": "common.schema.json#/$defs/UUID"
    },
    "entity_type": {
      "type": "string",
      "enum": [
        "camera_model",
        "lens_model",
        "listing",
        "price_observation"
      ]
    },
    "entity_id": {
      "$ref": "common.schema.json#/$defs/UUID"
    },
    "claim_path": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "source_type": {
      "type": "string",
      "enum": [
        "manufacturer",
        "wikidata",
        "wikipedia",
        "retailer",
        "marketplace",
        "manual",
        "other"
      ]
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "maxLength": 2048
    },
    "retrieved_at": {
      "$ref": "common.schema.json#/$defs/Timestamp"
    },
    "license": {
      "type": "string",
      "maxLength": 64
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "value": {
      "type": [
        "string",
        "number",
        "boolean",
        "null"
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 500
    }
  }
}