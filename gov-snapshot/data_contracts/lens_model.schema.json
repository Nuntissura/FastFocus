{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fastfocus.example/schemas/lens_model.schema.json",
  "title": "LensModel",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "lens_id",
    "slug",
    "brand",
    "display_name",
    "mount_code",
    "coverage_format",
    "lens_category",
    "focal_length_min_mm",
    "focal_length_max_mm",
    "max_aperture_wide_f",
    "max_aperture_tele_f",
    "has_is",
    "release",
    "production",
    "physical",
    "optical_specs",
    "aliases",
    "links",
    "content_modules",
    "evidence",
    "meta"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "lens_id": {
      "$ref": "common.schema.json#/$defs/UUID"
    },
    "slug": {
      "$ref": "common.schema.json#/$defs/Slug"
    },
    "brand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "brand_id",
        "name"
      ],
      "properties": {
        "brand_id": {
          "$ref": "common.schema.json#/$defs/UUID"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "slug": {
          "anyOf": [
            {
              "$ref": "common.schema.json#/$defs/Slug"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "display_name": {
      "type": "string",
      "minLength": 2,
      "maxLength": 120
    },
    "mount_code": {
      "$ref": "common.schema.json#/$defs/MountCode"
    },
    "coverage_format": {
      "anyOf": [
        {
          "$ref": "common.schema.json#/$defs/SensorFormat"
        },
        {
          "type": "null"
        }
      ]
    },
    "lens_category": {
      "$ref": "common.schema.json#/$defs/LensCategory"
    },
    "focal_length_min_mm": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2000
    },
    "focal_length_max_mm": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2000
    },
    "max_aperture_wide_f": {
      "type": "number",
      "minimum": 0.7,
      "maximum": 32.0
    },
    "max_aperture_tele_f": {
      "type": "number",
      "minimum": 0.7,
      "maximum": 32.0
    },
    "has_is": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "announce_date",
        "release_year",
        "msrp"
      ],
      "properties": {
        "announce_date": {
          "$ref": "common.schema.json#/$defs/ISODate"
        },
        "release_year": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1900,
          "maximum": 2100
        },
        "msrp": {
          "anyOf": [
            {
              "$ref": "common.schema.json#/$defs/Money"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "production": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start_year",
        "end_year",
        "is_discontinued",
        "confidence"
      ],
      "properties": {
        "start_year": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1900,
          "maximum": 2100
        },
        "end_year": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1900,
          "maximum": 2100
        },
        "is_discontinued": {
          "type": "boolean"
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        }
      }
    },
    "physical": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "weight_g",
        "weather_sealed"
      ],
      "properties": {
        "weight_g": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1,
          "maximum": 5000
        },
        "weather_sealed": {
          "type": [
            "boolean",
            "null"
          ]
        }
      }
    },
    "optical_specs": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "properties": {
        "filter_thread_mm": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 10,
          "maximum": 200
        },
        "min_focus_distance_m": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0.0,
          "maximum": 100.0
        },
        "max_magnification": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0.0,
          "maximum": 10.0
        },
        "aperture_blades": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 3,
          "maximum": 20
        },
        "elements": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1,
          "maximum": 40
        },
        "groups": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1,
          "maximum": 40
        }
      }
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 64
      },
      "maxItems": 50
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "manufacturer": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "manual": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "wikidata": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "wikipedia": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        }
      }
    },
    "content_modules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "used_buying_checklist",
        "known_issues"
      ],
      "properties": {
        "bio": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 4000
        },
        "used_buying_checklist": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/ChecklistItem"
          },
          "maxItems": 50
        },
        "known_issues": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/KnownIssue"
          },
          "maxItems": 50
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "source_evidence.schema.json"
      },
      "maxItems": 200
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "created_at",
        "updated_at"
      ],
      "properties": {
        "created_at": {
          "$ref": "common.schema.json#/$defs/Timestamp"
        },
        "updated_at": {
          "$ref": "common.schema.json#/$defs/Timestamp"
        }
      }
    }
  }
}
